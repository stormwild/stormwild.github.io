---
import '@styles/spacing.css'
import '@styles/color.css'
import '@styles/typography.css'
import '@styles/themes.css'
// import '@styles/base.css'
import 'modern-normalize/modern-normalize.css'
---

<!doctype html>
<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Design System Style Guide</title>
    <!-- <link rel='stylesheet' href='path/to/your/baseline.css' /> -->
    <!-- Link to your baseline CSS -->
  </head>
  <body>
    <div class='container'>
      <h1>Design System Style Guide</h1>

      <!-- Typography -->
      <section class='section'>
        <h2>Typography</h2>
        <div class='typography-example'>
          <h1>Heading 1</h1>
          <p>Description for Heading 1</p>
        </div>
        <div class='typography-example'>
          <h2>Heading 2</h2>
          <p>Description for Heading 2</p>
        </div>
        <!-- Repeat for other headings and text elements -->
      </section>

      <!-- Colors -->
      <section class='section'>
        <h2>Colors</h2>
        <div>
          <div
            class='color-swatch'
            style='background-color: var(--color-primary);'
          >
          </div>
          <div
            class='color-swatch'
            style='background-color: var(--color-success);'
          >
          </div>
          <!-- Repeat for other colors -->
        </div>
      </section>

      <!-- Spacing -->
      <section class='section'>
        <h2>Spacing</h2>
        <div>
          <!-- Example elements to demonstrate spacing, maybe divs with background color and different margins/paddings -->
        </div>
      </section>

      <!-- Buttons -->
      <section class='section'>
        <h2>Buttons</h2>
        <button>Primary Button</button>
        <button style='background-color: var(--color-secondary);'
          >Secondary Button</button
        >
        <!-- Repeat for other button styles -->
      </section>

      <!-- Forms -->
      <section class='section'>
        <h2>Forms</h2>
        <form>
          <div>
            <label for='inputExample'>Input Label</label>
            <input
              type='text'
              id='inputExample'
              placeholder='Input placeholder'
            />
          </div>
          <div>
            <label for='selectExample'>Select Label</label>
            <select id='selectExample'>
              <option>Option 1</option>
              <option>Option 2</option>
              <!-- Repeat for other options -->
            </select>
          </div>
          <!-- Repeat for other form elements -->
          <button type='submit'>Submit</button>
        </form>
      </section>
    </div>
  </body>
</html>

<style is:global>
  /* Additional styles for the style guide presentation */
  .container {
    max-width: 960px;
    margin: 0 auto;
    padding: var(--space-lg);
  }
  .section {
    margin-bottom: var(--space-xl);
  }
  .color-swatch {
    width: 100px;
    height: 100px;
    display: inline-block;
    margin-right: var(--space-md);
    border: 1px solid var(--color-border);
  }
  .typography-example {
    margin-bottom: var(--space-sm);
  }
</style>
