---
import 'modern-normalize'
import { SITE_TITLE, SITE_DESCRIPTION } from '@src/consts'
import MobileNavbar from '@src/components/MobileNavbar.astro'
import Sidebar from '@src/components/Sidebar.astro'

export interface Props {
  title?: string
}

const { title = 'Home' } = Astro.props
---

<!DOCTYPE html>
<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta http-equiv='X-UA-Compatible' content='IE=edge' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <link rel='icon' type='image/svg+xml' href='/favicon.svg' />
    <meta name='generator' content={Astro.generator} />
    <title>{title} - {SITE_TITLE}</title>
    <meta name='description' content={SITE_DESCRIPTION} />
  </head>
  <body>
    <div class='drawer drawer-mobile'>
      <input id='my-drawer' type='checkbox' class='drawer-toggle' />
      <div class='drawer-content flex justify-center lg:justify-start'>
        <div class='sm:w-[70vw] max-w-screen-lg lg:pt-14 lg:p-4'>
          <MobileNavbar />
          <div class='flex-1 p-3 md:py-[35]'>
            <div class='space-y-2 md:space-y-6'>
              <slot />
            </div>
            <!-- <Footer /> -->
          </div>
        </div>
      </div>
      <div class='drawer-side'>
        <label for='my-drawer' class='drawer-overlay'></label>
        <div class='overflow-y-auto flex lg:justify-end w-fit sm:w-[30vw]'>
          <div class='w-fit p-3 lg:m-6 bg-base-100'>
            <!-- {Config.siteImagePath && <SiteImage />} -->
            <h1 class='text-2xl p-2 pl-4'><a href='/'>Docs</a></h1>
            <p class='text-sm pl-4'>Awesome Docs</p>
            <!-- <SocialMedia /> -->
            <div class='divider'></div>
            <Sidebar />
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
