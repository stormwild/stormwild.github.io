---
const { serverCounter = 24 } = Astro.props;
---

<p>Counter: <span class="counter"></span></p>
<p>{serverCounter}</p>
<button type="button" class="counter-btn">+</button>

<style>
    .counter-btn {
        background-color: var(--color-gray-900);
        color: var(--color-gray-100);
        border: 0;
        border-radius: 4px;
        &:hover {
            /* cursor: pointer; */
            background-color: var(--color-gray-800);
        }
    }
</style>

<script src="@src/scripts/counter.ts"></script>
